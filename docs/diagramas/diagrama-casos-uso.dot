    UC06 [shape=ellipse, style="filled", fillcolor="#ffffff", color="#2f6f9f", label="Consultar\nRelatórios"];
    UC07 [shape=ellipse, style="filled", fillcolor="#ffffff", color="#2f6f9f", label="Acompanhar\nCronômetro"];
  }
