
digraph G {
  graph [rankdir=LR, bgcolor="white", pad="0.35", nodesep="0.6", ranksep="0.8", label="Diagrama Entidade-Relacionamento - FreelanceFlow", labelloc=t, fontsize=22, fontname="Helvetica-Bold"];
  node [shape=plain, fontname="Helvetica"]; edge [fontname="Helvetica", fontsize=10, color="#4b6070", arrowhead="crow", arrowtail="none"];
  clients [label=< <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" COLOR="#2b5c7a"><TR><TD BGCOLOR="#2b5c7a" COLSPAN="2"><FONT COLOR="white"><B>clients</B></FONT></TD></TR><TR><TD><B>PK</B></TD><TD ALIGN="LEFT">id uuid</TD></TR><TR><TD></TD><TD ALIGN="LEFT">name varchar(150)</TD></TR><TR><TD></TD><TD ALIGN="LEFT">email varchar(150)</TD></TR><TR><TD></TD><TD ALIGN="LEFT">phone varchar(30)</TD></TR><TR><TD></TD><TD ALIGN="LEFT">created_at timestamp</TD></TR></TABLE> >];
  projects [label=< <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" COLOR="#2b5c7a"><TR><TD BGCOLOR="#2b5c7a" COLSPAN="2"><FONT COLOR="white"><B>projects</B></FONT></TD></TR><TR><TD><B>PK</B></TD><TD ALIGN="LEFT">id uuid</TD></TR><TR><TD></TD><TD ALIGN="LEFT">name varchar(150)</TD></TR><TR><TD></TD><TD ALIGN="LEFT">description text</TD></TR><TR><TD></TD><TD ALIGN="LEFT">status varchar(50)</TD></TR><TR><TD><B>FK</B></TD><TD ALIGN="LEFT">client_id uuid</TD></TR></TABLE> >];
  activities [label=< <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" COLOR="#2b5c7a"><TR><TD BGCOLOR="#2b5c7a" COLSPAN="2"><FONT COLOR="white"><B>activities</B></FONT></TD></TR><TR><TD><B>PK</B></TD><TD ALIGN="LEFT">id uuid</TD></TR><TR><TD></TD><TD ALIGN="LEFT">description varchar(255)</TD></TR><TR><TD></TD><TD ALIGN="LEFT">status varchar(50)</TD></TR><TR><TD><B>FK</B></TD><TD ALIGN="LEFT">project_id uuid</TD></TR></TABLE> >];
  hours [label=< <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" COLOR="#2b5c7a"><TR><TD BGCOLOR="#2b5c7a" COLSPAN="2"><FONT COLOR="white"><B>hour_entries</B></FONT></TD></TR><TR><TD><B>PK</B></TD><TD ALIGN="LEFT">id uuid</TD></TR><TR><TD></TD><TD ALIGN="LEFT">worked_hours numeric(10,2)</TD></TR><TR><TD><B>FK</B></TD><TD ALIGN="LEFT">activity_id uuid</TD></TR><TR><TD></TD><TD ALIGN="LEFT">created_at timestamp</TD></TR></TABLE> >];
  payments [label=< <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" COLOR="#2b5c7a"><TR><TD BGCOLOR="#2b5c7a" COLSPAN="2"><FONT COLOR="white"><B>payments</B></FONT></TD></TR><TR><TD><B>PK</B></TD><TD ALIGN="LEFT">id uuid</TD></TR><TR><TD></TD><TD ALIGN="LEFT">value numeric(10,2)</TD></TR><TR><TD></TD><TD ALIGN="LEFT">method varchar(30)</TD></TR><TR><TD></TD><TD ALIGN="LEFT">status varchar(50)</TD></TR><TR><TD><B>FK</B></TD><TD ALIGN="LEFT">project_id uuid</TD></TR></TABLE> >];
  clients -> projects [label="1:N"];
  projects -> activities [label="1:N"];
  activities -> hours [label="1:N"];
  projects -> payments [label="1:N"];
}
